@model HomeViewModel
@{
    ViewData["Title"] = "Shop";
}

@* Inject server-rendered data as JS globals — no loading spinner on first paint *@
<script>
    window.__CATEGORIES__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Categories,
        new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }
    ));
    window.__PRODUCTS__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Products,
        new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }
    ));
</script>

<!-- ═══════════════ CATEGORIES ═══════════════ -->
<section class="categories-section">
    <div class="categories-container">
        <div class="categories-header">
            <h2 class="section-title">Shop by Category</h2>
            <button id="viewAllBtn" class="view-all-btn hidden">View All</button>
        </div>
        <div class="categories-mobile"  id="categoriesMobile"></div>
        <div class="categories-desktop" id="categoriesDesktop"></div>
    </div>
</section>

<!-- ═══════════════ PRODUCTS ═══════════════ -->
<main class="main-content">
    <section class="products-section">
        <div class="products-header">
            <h2 class="products-title" id="productsTitle">All Products</h2>
            <p  class="products-count"  id="productsCount">0 products available</p>
        </div>
        <div class="products-grid" id="productsGrid">
            @* Server-side initial render — JS will re-render on category filter *@
            @foreach (var product in Model.Products)
            {
                <div class="product-card">
                    <div class="product-image-wrapper" onclick="showProductDetails('@product.Id')">
                        <img src="@(product.ImageUrl ?? "https://images.unsplash.com/photo-1465161191540-aac346fcbaff?w=400")"
                             alt="@product.Name" class="product-image">
                        <button class="product-favorite-btn"
                                onclick="event.stopPropagation(); homeToggleFavorite('@product.Id')">
                            <svg class="product-favorite-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                            </svg>
                        </button>
                    </div>
                    <div class="product-info">
                        <h3 class="product-name" onclick="showProductDetails('@product.Id')">@product.Name</h3>
                        <div class="product-rating">
                            @for (int i = 0; i < 5; i++)
                            {
                                <svg class="star-icon @(i < Math.Floor(product.Rating) ? "filled" : "")"
                                     viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                                </svg>
                            }
                            <span class="product-reviews">(@product.ReviewsCount)</span>
                        </div>
                        <div class="product-footer">
                            <span class="product-price">$@product.Price.ToString("F2")</span>
                            <button class="product-cart-btn" onclick="addToCart('@product.Id')">
                                <svg class="product-cart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <circle cx="9" cy="21" r="1"></circle>
                                    <circle cx="20" cy="21" r="1"></circle>
                                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
</main>

@section Scripts {
    <script src="~/js/home.js" asp-append-version="true"></script>
}
