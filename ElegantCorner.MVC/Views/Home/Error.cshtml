@model ElegantCorner.MVC.Models.Errors.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<main class="main-content" style="padding-top: 8rem; text-align: center;">
    <h1 style="font-size: 2rem; font-weight: 700; color: #ef4444; margin-bottom: 1rem;">Something went wrong</h1>
    @if (Model.ShowRequestId)
    {
        <p style="color: #6b7280; font-size: 0.875rem;">Request ID: <code>@Model.RequestId</code></p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn-primary"
       style="display:inline-block;margin-top:1.5rem;padding:0.75rem 2rem;text-decoration:none;">
        Back to Home
    </a>
</main>
