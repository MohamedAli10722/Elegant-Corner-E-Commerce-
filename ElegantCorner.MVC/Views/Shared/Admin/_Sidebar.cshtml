@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();

    string IsActive(string c, string? a = null)
    {
        if (controller != c)
            return "";

        if (a == null)
            return "active";

        return action == a ? "active" : "";
    }
}

<aside class="sidebar" id="adminSidebar">

    <div class="sidebar-header">

        <h2>Modern Corner</h2>

        <span>Admin Panel</span>

    </div>

    <nav class="sidebar-menu">

        <a asp-controller="Admin"
           asp-action="Dashboard"
           class="@IsActive("Admin", "Dashboard")">

            <span class="sidebar-icon">🏠</span>
            <span class="sidebar-label">Dashboard</span>

        </a>

        <a asp-controller="Admin"
           asp-action="Categories"
           class="@IsActive("Admin", "Categories")">

            <span class="sidebar-icon">📂</span>
            <span class="sidebar-label">Categories</span>

        </a>

        <a asp-controller="Admin"
           asp-action="Products"
           class="@IsActive("Admin", "Products")">

            <span class="sidebar-icon">🛋️</span>
            <span class="sidebar-label">Products</span>

        </a>

        <a asp-controller="Admin"
           asp-action="Orders"
           class="@IsActive("Admin", "Orders")">

            <span class="sidebar-icon">🛒</span>
            <span class="sidebar-label">Orders</span>

        </a>

        <a asp-controller="Admin"
           asp-action="Settings"
           class="@IsActive("Admin", "Settings")">

            <span class="sidebar-icon">⚙️</span>
            <span class="sidebar-label">Settings</span>

        </a>

    </nav>

</aside>

<!-- Backdrop shown behind the sidebar when it's opened as a mobile drawer -->
<div class="sidebar-overlay" id="adminSidebarOverlay"></div>