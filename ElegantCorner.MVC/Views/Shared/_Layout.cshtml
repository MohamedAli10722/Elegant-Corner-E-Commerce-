<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Elegant Corner</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="header-content">
            <a asp-controller="Home" asp-action="Index" class="logo-link">
                <h1 class="logo">Elegant Corner</h1>
            </a>
            <div class="header-actions">
                <!-- Favorites Button -->
                <button id="favoritesBtn" class="icon-btn" aria-label="Favorites">
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                    </svg>
                    <span id="favoritesCount" class="badge badge-red hidden">0</span>
                </button>

                <!-- Cart Button -->
                <button id="cartBtn" class="icon-btn" aria-label="Shopping cart">
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <circle cx="9" cy="21" r="1"></circle>
                        <circle cx="20" cy="21" r="1"></circle>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                    </svg>
                    <span id="cartCount" class="badge badge-blue hidden">0</span>
                </button>

                <!-- User Button -->
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <button id="userBtn" class="icon-btn" aria-label="Account">
                        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </button>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="icon-btn" aria-label="Sign in">
                        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </a>
                }
            </div>
        </div>
    </header>

    <!-- Categories Section -->
    <section class="categories-section">
        <div class="categories-container">
            <div class="categories-header">
                <h2 class="section-title">Shop by Category</h2>
                <a asp-controller="Products" asp-action="Index" class="view-all-btn">View All</a>
            </div>

            <!-- Mobile Categories -->
            <div class="categories-mobile" id="categoriesMobile"></div>

            <!-- Desktop Categories -->
            <div class="categories-desktop" id="categoriesDesktop"></div>
        </div>
    </section>

    <!-- Main Content -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <p>© 2025 Elegant Corner. All rights reserved.</p>
        </div>
    </footer>

    <!-- Modals -->
    <!-- Cart Modal -->
    <div id="cartModal" class="modal hidden">
        <div class="modal-backdrop"></div>
        <div class="drawer">
            <div class="drawer-header">
                <h2 class="drawer-title">Shopping Cart</h2>
                <button class="modal-close" id="closeCartModal">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>

            <div class="drawer-content" id="cartContent"></div>

            <div class="drawer-footer hidden" id="cartFooter">
                <div class="cart-totals">
                    <div class="cart-total-row">
                        <span>Subtotal</span>
                        <span id="cartSubtotal">$0.00</span>
                    </div>
                    <div class="cart-total-row">
                        <span>Tax (10%)</span>
                        <span id="cartTax">$0.00</span>
                    </div>
                    <div class="cart-total-final">
                        <span>Total</span>
                        <span id="cartTotal">$0.00</span>
                    </div>
                </div>
                <button class="btn-primary">Proceed to Checkout</button>
            </div>
        </div>
    </div>

    <!-- Favorites Modal -->
    <div id="favoritesModal" class="modal hidden">
        <div class="modal-backdrop"></div>
        <div class="drawer">
            <div class="drawer-header">
                <h2 class="drawer-title">My Favorites</h2>
                <button class="modal-close" id="closeFavoritesModal">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>

            <div class="drawer-content" id="favoritesContent"></div>
        </div>
    </div>

    <!-- Product Details Modal -->
    <div id="productDetailsModal" class="modal hidden">
        <div class="modal-backdrop"></div>
        <div class="details-modal">
            <button class="modal-close" id="closeProductDetailsModal">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <div id="productDetailsContent"></div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/js/script.js"></script>
</body>
</html>
