<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Elegant Corner</title>
    <!-- Shared styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ═══════════════════════════════════════════════════════════
         HEADER  (always visible)
    ════════════════════════════════════════════════════════════════ -->
    <header class="header">
        <div class="header-content">
            <a asp-controller="Home" asp-action="Index" class="logo">Elegant Corner</a>

            <div class="header-actions">
                <!-- Admin Panel (only visible when signed in) -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Admin" asp-action="Dashboard" class="admin-btn" aria-label="Admin panel">
                        <svg class="admin-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M12 2 4 6v6c0 5 3.4 8.4 8 10 4.6-1.6 8-5 8-10V6l-8-4z"></path>
                        </svg>
                        <span class="admin-btn-label">Admin</span>
                    </a>
                }
                <!-- Favorites -->
                <button id="favoritesBtn" class="icon-btn" aria-label="Favorites">
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                    </svg>
                    <span id="favoritesCount" class="badge badge-red hidden">0</span>
                </button>

                <!-- Cart -->
                <button id="cartBtn" class="icon-btn" aria-label="Shopping cart">
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <circle cx="9" cy="21" r="1"></circle>
                        <circle cx="20" cy="21" r="1"></circle>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                    </svg>
                    <span id="cartCount" class="badge badge-blue hidden">0</span>
                </button>

                <!-- User: shows icon + logout confirm when logged in, opens auth modal when not -->
                <button id="userBtn" class="icon-btn @(User.Identity?.IsAuthenticated == true ? "is-authenticated" : "")"
                        aria-label="Account"
                        data-display-name="@User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value">
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </button>
            </div>
        </div>
    </header>

    <!-- ═══════════════════════════════════════════════════════════
         PAGE BODY  (categories + products injected per-page)
    ════════════════════════════════════════════════════════════════ -->
    @RenderBody()

    <!-- ═══════════════════════════════════════════════════════════
         FOOTER
    ════════════════════════════════════════════════════════════════ -->
    <footer class="footer">
        <div class="footer-content">
            <p>&copy; 2025 Elegant Corner. All rights reserved.</p>
        </div>
    </footer>

    <!-- ═══════════════════════════════════════════════════════════
         AUTH MODAL (sign in / sign up)
    ════════════════════════════════════════════════════════════════ -->
    <div id="signUpModal" class="modal hidden">
        <div class="modal-backdrop"></div>
        <div class="auth-modal" id="authModal">
            <button class="modal-close" id="closeSignUpModal">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>

            <!-- Sign In Form -->
            <div class="auth-form-container" id="signInContainer">
                <h2 class="auth-title">Sign In</h2>
                <p class="auth-subtitle">Use your account</p>
                <form id="signInForm" class="auth-form">
                    <div class="input-group">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                        <input type="email" id="loginEmail" placeholder="Email" required>
                    </div>
                    <div class="input-group">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                        <input type="password" id="loginPassword" placeholder="Password" required>
                    </div>
                    <div class="forgot-password"><a href="#">Forgot your password?</a></div>
                    <button type="submit" class="btn-primary">Sign In</button>
                </form>
                <div class="social-divider"><span>Or sign in with</span></div>
                <div class="social-buttons">
                    <button class="social-btn">
                        <svg viewBox="0 0 24 24">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                        </svg>
                    </button>
                    <button class="social-btn">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Sign Up Form -->
            <div class="auth-form-container" id="signUpContainer">
                <h2 class="auth-title">Create Account</h2>
                <p class="auth-subtitle">Use your email for registration</p>
                <form id="signUpForm" class="auth-form">
                    <div class="input-group">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                        <input type="text" id="registerName" placeholder="Name" required>
                    </div>
                    <div class="input-group">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                        <input type="email" id="registerEmail" placeholder="Email" required>
                    </div>
                    <div class="input-group">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                        <input type="password" id="registerPassword" placeholder="Password" required>
                    </div>
                    <div class="input-group">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                        <input type="password" id="registerConfirmPassword" placeholder="Confirm Password" required>
                    </div>
                    <button type="submit" class="btn-primary">Sign Up</button>
                </form>
                <div class="social-divider"><span>Or sign up with</span></div>
                <div class="social-buttons">
                    <button class="social-btn">
                        <svg viewBox="0 0 24 24">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                        </svg>
                    </button>
                    <button class="social-btn">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Blue Sliding Panel (desktop) -->
            <div class="auth-panel" id="authPanel">
                <div class="auth-panel-content">
                    <h2 class="panel-title" id="panelTitle">Hello, Friend!</h2>
                    <p class="panel-text" id="panelText">Enter your personal details and start your journey with us</p>
                    <button class="btn-outline" id="toggleAuthBtn">Sign Up</button>
                </div>
            </div>

            <!-- Mobile Toggle -->
            <div class="mobile-toggle">
                <p id="mobileToggleText">Don't have an account?</p>
                <button class="btn-outline-mobile" id="mobileToggleBtn">Sign Up</button>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         CART DRAWER
    ════════════════════════════════════════════════════════════════ -->
    <div id="cartModal" class="modal hidden">
        <div class="modal-backdrop"></div>
        <div class="drawer">
            <div class="drawer-header">
                <h2 class="drawer-title">Shopping Cart</h2>
                <button class="modal-close" id="closeCartModal">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
            <div class="drawer-content" id="cartContent"></div>
            <div class="drawer-footer hidden" id="cartFooter">
                <div class="cart-totals">
                    <div class="cart-total-row">
                        <span>Subtotal</span><span id="cartSubtotal">$0.00</span>
                    </div>
                    <div class="cart-total-row">
                        <span>Tax (10%)</span><span id="cartTax">$0.00</span>
                    </div>
                    <div class="cart-total-final">
                        <span>Total</span><span id="cartTotal">$0.00</span>
                    </div>
                </div>
                <button class="btn-primary" id="checkoutBtn">Proceed to Checkout</button>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         FAVORITES DRAWER
    ════════════════════════════════════════════════════════════════ -->
    <div id="favoritesModal" class="modal hidden">
        <div class="modal-backdrop"></div>
        <div class="drawer">
            <div class="drawer-header">
                <h2 class="drawer-title">My Favorites</h2>
                <button class="modal-close" id="closeFavoritesModal">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
            <div class="drawer-content" id="favoritesContent"></div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         PRODUCT DETAILS MODAL
    ════════════════════════════════════════════════════════════════ -->
    <div id="productDetailsModal" class="modal hidden">
        <div class="modal-backdrop"></div>
        <div class="details-modal">
            <button class="modal-close" id="closeProductDetailsModal">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <div id="productDetailsContent"></div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         SHARED SCRIPTS  (loaded on every page)
    ════════════════════════════════════════════════════════════════ -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
