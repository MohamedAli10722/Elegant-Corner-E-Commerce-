@model ElegantCorner.Web.ViewModels.ProductFormViewModel

<div class="card shadow-sm border-0">

    <div class="card-header bg-white">
        <h4 class="mb-0">@ViewData["Title"]</h4>
    </div>

    <div class="card-body">

        <form asp-action="@(Model.Id == Guid.Empty ? "CreateProduct" : "EditProduct")"
              method="post"
              enctype="multipart/form-data">

            @if (Model.Id != Guid.Empty)
            {
                <input asp-for="Id" type="hidden" />
            }

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3"></div>

            <div class="row">

                <!-- Product Name -->

                <div class="col-md-6 mb-3">

                    <label asp-for="Name" class="form-label"></label>

                    <input asp-for="Name" class="form-control" />

                    <span asp-validation-for="Name"
                          class="text-danger"></span>

                </div>

                <!-- Price -->

                <div class="col-md-6 mb-3">

                    <label asp-for="Price" class="form-label"></label>

                    <input asp-for="Price"
                           type="number"
                           step="0.01"
                           class="form-control" />

                    <span asp-validation-for="Price"
                          class="text-danger"></span>

                </div>

            </div>

            <!-- Description -->

            <div class="mb-3">

                <label asp-for="Description"
                       class="form-label"></label>

                <textarea asp-for="Description"
                          rows="4"
                          class="form-control"></textarea>

            </div>

            <!-- Category -->

            <div class="mb-3">

                <label asp-for="CategoryId"
                       class="form-label"></label>

                <select asp-for="CategoryId"
                        asp-items="Model.Categories"
                        class="form-select">

                    <option value="">Select Category</option>

                </select>

            </div>

            <!-- Image -->

            <div class="mb-3">

                <label class="form-label">
                    Product Image
                </label>

                <input asp-for="Image"
                       type="file"
                       class="form-control"
                       accept="image/*"
                       onchange="previewImage(event)" />

            </div>

            <!-- Current Image -->

            <div class="mb-3">

                <img id="preview"
                     src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "" : Model.ImageUrl)"
                     style="max-width:200px;
                            border-radius:10px;
                            @(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")" />

            </div>

            <!-- Available -->

            <div class="form-check mb-4">

                <input asp-for="IsAvailable"
                       class="form-check-input" />

                <label asp-for="IsAvailable"
                       class="form-check-label">
                    Available
                </label>

            </div>

            <button class="btn btn-primary">

                <i class="bi bi-check-circle"></i>

                Save Product

            </button>

            <a asp-action="Products"
               class="btn btn-secondary">

                Cancel

            </a>

        </form>

    </div>

</div>

@section Scripts {

    <script>

        function previewImage(event){

            const preview=document.getElementById("preview");

            preview.src=URL.createObjectURL(event.target.files[0]);

            preview.style.display="block";

        }

    </script>

}