@model ElegantCorner.MVC.Models.ViewModels.CreateCategoryViewModel

@{
    ViewData["Title"] = "Add Category";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">

    <div class="page-title">

        <h1>Add Category</h1>

        <p>Create a new category for your store.</p>

    </div>

    <a asp-action="Categories"
       class="btn btn-secondary">

        Back

    </a>

</div>

<div class="admin-card">

    <form asp-action="CreateCategory"
          method="post"
          enctype="multipart/form-data">

        <div class="form-layout">

            <!-- Left Side -->

            <div>

                <div class="form-group">

                    <label asp-for="Name"></label>

                    <input asp-for="Name"
                           class="input" />

                    <span asp-validation-for="Name"
                          class="validation"></span>

                </div>

                <div class="form-group">

                    <label asp-for="Description"></label>

                    <textarea asp-for="Description"
                              class="textarea"></textarea>

                    <span asp-validation-for="Description"
                          class="validation"></span>

                </div>

                <div class="form-group">

                    <label asp-for="Icon"></label>

                    <input asp-for="Icon"
                           class="input"
                           placeholder="bi bi-house" />

                    <span asp-validation-for="Icon"
                          class="validation"></span>

                </div>

            </div>

            <!-- Right Side -->

            <div>

                <div class="form-group">

                    <label>Category Image</label>

                    <label class="upload-box">

                        <input asp-for="Image"
                               id="imageInput"
                               type="file"
                               accept="image/*"
                               hidden />

                        <h3>📁</h3>

                        <strong>Choose Image</strong>

                        <span>Click here to upload</span>

                    </label>

                </div>

                <div class="preview-image">

                    <img id="previewImage"
                         src="/images/no-image.png"
                         alt="Preview" />

                </div>

            </div>

        </div>

        <div class="form-actions">

            <a asp-action="Categories"
               class="btn btn-secondary">

                Cancel

            </a>

            <button type="submit"
                    class="btn btn-primary">

                Save Category

            </button>

        </div>

    </form>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

        const imageInput = document.getElementById("imageInput");
        const previewImage = document.getElementById("previewImage");

        imageInput.addEventListener("change", function () {

            if (this.files.length > 0) {

                previewImage.src = URL.createObjectURL(this.files[0]);

            }

        });

    </script>

}