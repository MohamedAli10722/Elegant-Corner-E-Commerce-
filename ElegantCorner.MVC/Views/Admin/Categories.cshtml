@model IEnumerable<ElegantCorner.Application.DTOs.Category.CategoryDto>

@{
    ViewData["Title"] = "Categories";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">

    <div class="page-title">

        <h1>Categories</h1>

        <p>Manage your store categories</p>

    </div>

    <a asp-action="CreateCategory" class="btn btn-primary btn-sm">
        + Add Category
    </a>

</div>

@if (!Model.Any())
{
    <div class="admin-card">

        <div class="empty-state">

            <h2>No Categories Found</h2>

            <p>
                Start by creating your first category.
            </p>

            <a asp-action="CreateCategory"
               class="btn btn-primary">

                + Add Category

            </a>

        </div>

    </div>
}
else
{
    <div class="category-grid">

        @foreach (var item in Model)
        {
            <div class="category-card">

                <div class="category-image">

                    <img src="@item.ImageUrl"
                         alt="@item.Name"
                         onerror="this.src='/images/no-image.png'" />

                </div>

                <div class="category-body">

                    <h3>@item.Name</h3>

                    <p>
                        @(string.IsNullOrWhiteSpace(item.Description)
                                        ? "No description available."
                                        : item.Description)
            </p>

                    <div class="category-actions">

                        <a asp-action="EditCategory"
                           asp-route-id="@item.Id"
                           class="btn btn-warning">

                            Edit

                        </a>

                        <a asp-action="DeleteCategory"
                           asp-route-id="@item.Id"
                           class="btn btn-danger">

                            Delete

                        </a>

                    </div>

                </div>

            </div>
        }

    </div>
}